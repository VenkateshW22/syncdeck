# ---------------------------------------------------------------------------
# SyncDeck environment configuration
# Copy this file to .env for local development and fill in real values.
# In production these are required — the server (server/config/env.ts)
# refuses to start if any are missing or left at an insecure placeholder.
# ---------------------------------------------------------------------------

# Standard Node environment. Set to "production" in deployed environments.
NODE_ENV=development

# Port the HTTP/WebSocket server listens on.
PORT=3000

# JWT signing secrets. MUST be long, random, and different from each other.
# Generate with: openssl rand -base64 48
JWT_SECRET=
REFRESH_SECRET=

# Postgres connection string. Without this in production the server refuses
# to start rather than silently falling back to an embedded, non-persistent
# database.
# Example: postgresql://user:password@host:5432/syncdeck
DATABASE_URL=

# Optional: override the dynamically-calculated Postgres pool size.
# DB_POOL_MAX=20

# Only used by docker-compose.prod.yml to set the password for the bundled
# Postgres container. Not read by the app itself (the app reads DATABASE_URL).
POSTGRES_PASSWORD=

# Redis connection string. Required in production for rate limiting, replay
# protection, session/canvas state, and Socket.IO's cross-instance adapter.
# Example: redis://user:password@host:6379
REDIS_URL=

# The externally-reachable origin of this app (scheme + host, no trailing
# slash), used for Socket.IO CORS and for building shareable/download links.
# Example: https://app.syncdeck.example.com
APP_ORIGIN=
APP_URL=

# Optional: caps applied to in-session state (sane defaults are used if unset).
# MAX_CHAT_HISTORY=100
# MAX_CANVAS_LAYERS=3000
# MAX_HYDRATION_SIZE=5242880

# Optional: only needed if/when the AI-assisted session summary feature is
# wired up to the Gemini API. Currently unused by the server.
# GEMINI_API_KEY=
