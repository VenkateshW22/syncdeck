{
  "info": {
    "_postman_id": "7b3b4f62-38d5-4cda-92ee-e9dc2a11b65e",
    "name": "SyncDeck API Tests",
    "description": "Automated test suite for validating JWT security filters, room operations, and standard REST responses in SyncDeck.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Liveness Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response returns status ok\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"ok\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Room (Host)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Verify token and code exist\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"hostToken\");",
              "    pm.expect(jsonData).to.have.property(\"roomCode\");",
              "    pm.expect(jsonData).to.have.property(\"hostId\");",
              "    ",
              "    // Set variables for subsequent steps",
              "    pm.collectionVariables.set(\"roomCode\", jsonData.roomCode);",
              "    pm.collectionVariables.set(\"hostToken\", jsonData.hostToken);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"hostName\": \"Dr. Watson\",\n    \"persistOnClose\": false,\n    \"waitingRoomEnabled\": false,\n    \"adminKey\": \"VK2212\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/rooms",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "rooms"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Join Room (Participant)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Verify participant token and status\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"token\");",
              "    pm.expect(jsonData.status).to.be.oneOf([\"ONLINE\", \"PENDING\"]);",
              "    ",
              "    // Set variable for subsequent steps",
              "    pm.collectionVariables.set(\"participantToken\", jsonData.token);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"displayName\": \"John Doe\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/rooms/{{roomCode}}/join",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "rooms",
            "{{roomCode}}",
            "join"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Resources (Valid JWT)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response is an array of resources\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{hostToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rooms/resources",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "rooms",
            "resources"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Resources (Missing Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 401 Unauthorized\", function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "pm.test(\"Error payload includes message\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.error).to.include(\"Unauthorized\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rooms/resources",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "rooms",
            "resources"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Resources (Invalid Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 401 Unauthorized\", function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer thisIsAnInvalidMalformedTokenStringValue"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rooms/resources",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "rooms",
            "resources"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Audit Logs (Host Authorized)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response returns logs array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{hostToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rooms/audit-logs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "rooms",
            "audit-logs"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Audit Logs (Participant Forbidden)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 403 Forbidden\", function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "pm.test(\"Error payload includes Forbidden\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.error).to.include(\"Forbidden\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{participantToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rooms/audit-logs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "rooms",
            "audit-logs"
          ]
        }
      },
      "response": []
    }
  ],
