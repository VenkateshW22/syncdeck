# ---------------------------------------------------------------------------
# SyncDeck — Staging environment template
# Copy to .env.staging and fill in real values. NEVER commit .env.staging.
# Staging mirrors production config but can use smaller resources.
# ---------------------------------------------------------------------------

NODE_ENV=staging
PORT=3000

# Generate with: openssl rand -base64 48
# Must be ≥32 chars and different from each other.
JWT_SECRET=
REFRESH_SECRET=

# Staging Postgres — can be a smaller instance (e.g. db.t3.micro on RDS)
# Example: postgresql://syncdeck:password@staging-db.internal:5432/syncdeck
DATABASE_URL=

# Optional: override pool size (default: 10)
# DB_POOL_MAX=10

# Only used by docker-compose.staging.yml bundled Postgres container
POSTGRES_PASSWORD=

# Staging Redis (single-node is fine for staging)
# Example: redis://staging-redis.internal:6379
REDIS_URL=

# Publicly reachable URL of the staging deployment
APP_ORIGIN=https://staging.syncdeck.example.com
APP_URL=https://staging.syncdeck.example.com

# Client-side env (picked up by Vite at build time)
VITE_APP_ENV=staging
VITE_APP_NAME=SyncDeck (Staging)

# Optional tuning
# MAX_CHAT_HISTORY=100
# MAX_CANVAS_LAYERS=3000
# MAX_HYDRATION_SIZE=5242880

# Optional: Gemini API key for AI-assisted session summaries
# GEMINI_API_KEY=
