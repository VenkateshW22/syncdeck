# ---------------------------------------------------------------------------
# SyncDeck — Production environment template
# Copy to .env.production and fill in real values. NEVER commit .env.production.
# The server refuses to start if any required var is missing or insecure.
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=3000

# ---------------------------------------------------------------------------
# REQUIRED — server exits if missing/insecure
# ---------------------------------------------------------------------------

# Generate with: openssl rand -base64 48
# Must be ≥32 chars, unique, and different from REFRESH_SECRET.
JWT_SECRET=

# Generate with: openssl rand -base64 48
# Must be ≥32 chars, unique, and different from JWT_SECRET.
REFRESH_SECRET=

# Fully-qualified Postgres connection string.
# Standard: postgresql://syncdeck_user:StrongPassw0rd@db.internal:5432/syncdeck
# GCP Cloud SQL (VPC/Direct IP): postgresql://postgres:PASSWORD@10.x.x.x:5432/syncdeck?sslmode=disable
# GCP Cloud SQL (Unix Socket via Cloud SQL Auth Proxy): postgresql://postgres:PASSWORD@localhost/syncdeck?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# Optional: maximum Postgres pool connections (default: auto-calculated).
# DB_POOL_MAX=20

# Only used by docker-compose.prod.yml bundled Postgres container.
# Use a managed Postgres (RDS / Cloud SQL / Supabase) in real production.
POSTGRES_PASSWORD=

# Redis connection string. Required for rate limiting, replay protection,
# canvas/chat state, and Socket.IO cross-instance pub/sub.
# Example: redis://syncdeck_redis:StrongPassw0rd@redis.internal:6379
REDIS_URL=

# Publicly reachable origin of this app (scheme + host, NO trailing slash).
# Used for Socket.IO CORS and building download/shareable links.
APP_ORIGIN=https://app.syncdeck.example.com
APP_URL=https://app.syncdeck.example.com

# ---------------------------------------------------------------------------
# CLIENT-SIDE (Vite bakes these in at build time — no secrets here!)
# ---------------------------------------------------------------------------
VITE_APP_ENV=production
VITE_APP_NAME=SyncDeck

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------
# MAX_CHAT_HISTORY=100
# MAX_CANVAS_LAYERS=3000
# MAX_HYDRATION_SIZE=5242880
# GEMINI_API_KEY=
